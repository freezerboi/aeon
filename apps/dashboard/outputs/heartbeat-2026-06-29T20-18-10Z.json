{
  "root": "card",
  "state": {},
  "elements": {
    "card": {
      "type": "Card",
      "props": {
        "title": "Heartbeat"
      },
      "children": [
        "status-stack"
      ]
    },
    "status-stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "watch-badge-stack",
        "memory-alert"
      ]
    },
    "watch-badge-stack": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "sm"
      },
      "children": [
        "watch-badge",
        "watch-label"
      ]
    },
    "watch-badge": {
      "type": "Badge",
      "props": {
        "text": "🟡 WATCH",
        "variant": "outline"
      }
    },
    "watch-label": {
      "type": "Text",
      "props": {
        "text": "Heartbeat",
        "variant": "muted"
      }
    },
    "memory-alert": {
      "type": "Alert",
      "props": {
        "title": "🔵 MEMORY",
        "message": "Configure notification channels (Telegram/Discord/Slack) and run first digest — flagged in MEMORY.md, not yet actioned.",
        "type": "info"
      }
    }
  }
}
